generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Memo {
  id          String   @id @default(cuid())
  title       String
  body        String
  photoName   String?
  photoType   String?
  photoDataUrl String? @db.Text
  latitude    Float?
  longitude   Float?
  rangeLabel  String?
  rangeMeters Int?
  ownerId     String
  ownerEmail  String
  ownerName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  likes       MemoLike[]
  comments    MemoComment[]

  @@index([ownerId])
  @@index([ownerEmail])
}

model MemoLike {
  id        String   @id @default(cuid())
  memoId    String
  memo      Memo     @relation(fields: [memoId], references: [id], onDelete: Cascade)
  userId    String
  userEmail String
  userName  String?
  createdAt DateTime @default(now())

  @@unique([memoId, userId])
  @@index([memoId])
}

model MemoComment {
  id        String   @id @default(cuid())
  memoId    String
  memo      Memo     @relation(fields: [memoId], references: [id], onDelete: Cascade)
  body      String
  userId    String
  userEmail String
  userName  String?
  createdAt DateTime @default(now())

  @@index([memoId])
}
